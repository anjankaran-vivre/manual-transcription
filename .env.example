# Streamlit Frontend - Configuration

# ============================================================================
# GROQ API CONFIGURATION
# ============================================================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# ZOHO CRM OAUTH CONFIGURATION
# ============================================================================
# Get these from your Zoho CRM OAuth settings
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REDIRECT_URI=http://localhost:8501

# ============================================================================
# AUDIO DOWNLOAD CREDENTIALS (Optional)
# ============================================================================
# If your audio URLs require authentication, provide credentials
AUDIO_USERNAME=your_username
AUDIO_PASSWORD=your_password
